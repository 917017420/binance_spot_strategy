# Rendered by scripts/install_systemd_service.sh.
# Adjust values here after install if the service needs different operational defaults.

BINANCE_STRATEGY_REPO_DIR=__REPO_DIR__
BINANCE_STRATEGY_PYTHON=__PYTHON_BIN__
BINANCE_STRATEGY_CONFIG=__CONFIG_PATH__
BINANCE_STRATEGY_ENV_FILE=__ENV_FILE_PATH__

# Resident runtime defaults used by scripts/systemd_runtime.sh start.
BINANCE_STRATEGY_ACTION_MODE=__ACTION_MODE__
BINANCE_STRATEGY_SLEEP_SECONDS=__SLEEP_SECONDS__
BINANCE_STRATEGY_SLEEP_HEARTBEAT_SECONDS=__SLEEP_HEARTBEAT_SECONDS__
BINANCE_STRATEGY_LOG_LEVEL=__LOG_LEVEL__

# Keep this true for normal service operation so a prior graceful stop does not block the next systemctl start.
# Set it to false if you want every new start to require a manual clear-runner-stop first.
BINANCE_STRATEGY_CLEAR_STOP_SIGNAL=__CLEAR_STOP_SIGNAL__

# Graceful stop settings used by scripts/systemd_runtime.sh stop.
BINANCE_STRATEGY_STOP_REASON=__STOP_REASON__
BINANCE_STRATEGY_STOP_TIMEOUT_SECONDS=__STOP_TIMEOUT_SECONDS__
BINANCE_STRATEGY_STOP_POLL_SECONDS=__STOP_POLL_SECONDS__
